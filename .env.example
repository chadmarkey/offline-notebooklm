# Copy this file to .env and fill in the value below.
# .env is gitignored — keep it that way; it holds a secret.
#
# Open Notebook encrypts your saved provider credentials with this key.
# Generate it once and do not change it: if the key changes, previously
# stored credentials become unreadable and you'll have to re-enter them.
#
#   openssl rand -hex 32
#
OPEN_NOTEBOOK_ENCRYPTION_KEY=
